/**
 * GlowEarn Security Rules
 * 
 * Core Philosophy:
 * This ruleset implements a strict path-based ownership model combined with administrative overrides.
 * Authorization is primarily determined by the document path (UID matching), ensuring that users 
 * can only access their own financial and profile data without requiring expensive cross-document lookups.
 * 
 * Data Structure:
 * - /users/{userId}: Primary profile and balance data.
 * - /users/{userId}/transactions: Private history of earnings/withdrawals.
 * - /users/{userId}/earningRecommendations: Personalized AI suggestions.
 * - /adminRoles/{adminId}: A registry of UIDs granted elevated privileges.
 * - /usernames/{username}: A registry used to ensure global uniqueness of handles.
 * - /leaderboardEntries/{id}: Publicly readable ranking data.
 * 
 * Key Security Decisions:
 * - Authorization Independence: By nesting user-specific data under /users/{userId}, we use the 
 *   wildcard in the path for immediate ownership verification.
 * - Global Admin Bypass: The user 'developerge@gmail.com' and any UID present in /adminRoles 
 *   bypass standard ownership restrictions.
 * - Unique Registry Pattern: Usernames are managed in a separate collection to allow for 
 *   atomic availability checks during the signup process.
 * - Relational Integrity: Critical fields like 'userId' or 'id' are validated to match 
 *   the document path during creation and are made immutable during updates.
 */

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * Checks if the current user is the owner based on the provided userId.
     */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /**
     * Checks if the authenticated user has administrative privileges.
     * Includes a specific bypass for the developer email and checks the /adminRoles collection.
     */
    function isAdmin() {
      return isSignedIn() && (request.auth.token.email == 'developerge@gmail.com' || exists(/databases/$(database)/documents/adminRoles/$(request.auth.uid)));
    }

    /**
     * Checks ownership for an existing document and ensures the document exists.
     */
    function isExistingOwner(userId) {
      return isOwner(userId) && resource != null;
    }

    // --- Collection Rules ---

    /**
     * @description Rules for user profile documents containing balances and settings.
     * @path /users/{userId}
     * @allow (get) If user is owner or admin.
     * @deny (create) If request.auth.uid does not match the userId in the path.
     * @principle Path-based ownership and relational integrity between path and data.
     */
    match /users/{userId} {
      allow get, list: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if (isExistingOwner(userId) || isAdmin()) && request.resource.data.id == resource.data.id;
      allow delete: if isAdmin();
    }

    /**
     * @description Private subcollection of financial transactions.
     * @path /users/{userId}/transactions/{transactionId}
     * @allow (list) If user owns the parent user document.
     * @deny (update) By standard users; transactions are generally immutable for users.
     * @principle Hierarchical path-based authorization.
     */
    match /users/{userId}/transactions/{transactionId} {
      allow get, list: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && request.resource.data.userId == userId;
      allow update, delete: if isAdmin();
    }

    /**
     * @description AI-generated earning recommendations personalized for each user.
     * @path /users/{userId}/earningRecommendations/{recommendationId}
     * @allow (update) User can update to mark as 'isCompleted'.
     * @deny (create) By standard users; these are system-generated.
     * @principle Restricts creation to system/admin while allowing user interaction.
     */
    match /users/{userId}/earningRecommendations/{recommendationId} {
      allow get, list: if isOwner(userId) || isAdmin();
      allow create: if isAdmin();
      allow update: if (isExistingOwner(userId) || isAdmin()) && request.resource.data.userId == resource.data.userId;
      allow delete: if isAdmin();
    }

    /**
     * @description Global registry for enforcing unique usernames.
     * @path /usernames/{username}
     * @allow (get) For all signed-in users to check if a username is taken.
     * @deny (list) To prevent scraping the entire user directory.
     * @principle Unique lookup pattern for global constraints.
     */
    match /usernames/{username} {
      allow get: if isSignedIn();
      allow list: if false;
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    /**
     * @description Collection used to define administrative roles.
     * @path /adminRoles/{adminId}
     * @allow (get, list, write) Only for existing administrators.
     * @deny (write) For any non-admin user.
     * @principle Role-based access control (RBAC) via dedicated registry.
     */
    match /adminRoles/{adminId} {
      allow get, list, create, update, delete: if isAdmin();
    }

    /**
     * @description Publicly visible leaderboard based on total earnings.
     * @path /leaderboardEntries/{leaderboardEntryId}
     * @allow (get, list) For all signed-in users.
     * @deny (write) For standard users; entries are managed by system processes.
     * @principle Public read with authorized system-level writes.
     */
    match /leaderboardEntries/{leaderboardEntryId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }
  }
}